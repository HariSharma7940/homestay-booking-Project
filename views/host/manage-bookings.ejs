<%- include('../partials/header') %>
</head>
<body class="bg-gray-100 flex flex-col min-height-screen">
    <%- include('../partials/navigation') %>

    <main class="flex-1" style="max-width: 900px; margin: 2rem auto; padding: 0 1.5rem; width: 100%; box-sizing: border-box; font-family: sans-serif;">

        <!-- Header -->
        <div style="text-align: center; margin-bottom: 2rem;">
            <h1 style="color: #0d9488; font-size: 2rem; font-weight: 700; margin: 0;">Booking Requests</h1>
            <p style="color: #6b7280; font-size: 14px; margin: 6px 0 0;">Manage check-ins and bookings for your homestays</p>
            <% if (bookings.length > 0) { %>
                <span style="display: inline-block; margin-top: 10px; background-color: #0d9488; color: white; font-size: 13px; font-weight: 600; padding: 4px 14px; border-radius: 20px;">
                    <%= bookings.length %> Total Booking<%= bookings.length > 1 ? 's' : '' %>
                </span>
            <% } %>
        </div>

        <% if (bookings.length === 0) { %>

            <!-- Empty State -->
            <div style="text-align: center; background: white; border-radius: 16px; padding: 4rem 2rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                <p style="font-size: 4rem; margin: 0;">📋</p>
                <h2 style="font-size: 1.3rem; font-weight: 700; color: #374151; margin: 1rem 0 0.5rem;">No booking requests yet!</h2>
                <p style="font-size: 14px; color: #6b7280; margin: 0;">When guests book your listed homestays, they will appear here for your approval.</p>
            </div>

        <% } else { %>

            <% bookings.forEach(booking => { %>

                <!-- Booking Request Card -->
                <div style="background: white; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); margin-bottom: 1.5rem; overflow: hidden; border-left: 5px solid <%= booking.status === 'Approved' ? '#0d9488' : booking.status === 'Rejected' ? '#ef4444' : booking.status === 'Cancelled' ? '#9ca3af' : '#f59e0b' %>; display: flex; flex-direction: column;">
                    
                    <div style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
                        
                        <!-- Top Row: Home Name & Status Badge -->
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 10px; border-bottom: 1px solid #f1f5f9; padding-bottom: 10px;">
                            <div>
                                <h3 style="font-size: 18px; font-weight: 700; color: #111827; margin: 0;">
                                    <%= booking.homeId ? booking.homeId.houseName : 'Deleted Homestay' %>
                                </h3>
                                <p style="font-size: 13px; color: #6b7280; margin: 2px 0 0;">📍 <%= booking.homeId ? booking.homeId.location : 'N/A' %></p>
                            </div>
                            
                            <!-- Status Badges -->
                            <% if (booking.status === 'Approved') { %>
                                <span style="background-color: #ccfbf1; color: #0f766e; font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 20px; border: 1px solid #a7f3d0;">
                                    ✅ Approved
                                </span>
                            <% } else if (booking.status === 'Rejected') { %>
                                <span style="background-color: #fee2e2; color: #b91c1c; font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 20px; border: 1px solid #fca5a5;">
                                    ❌ Rejected
                                </span>
                            <% } else if (booking.status === 'Cancelled') { %>
                                <span style="background-color: #f3f4f6; color: #4b5563; font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 20px; border: 1px solid #e5e7eb;">
                                    🚫 Cancelled by Guest
                                </span>
                            <% } else { %>
                                <span style="background-color: #fef3c7; color: #d97706; font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 20px; border: 1px solid #fde68a;">
                                    ⏳ Pending Approval
                                </span>
                            <% } %>
                        </div>

                        <!-- Guest Info -->
                        <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; background: #f9fafb; border-radius: 10px; padding: 12px 16px; border: 1px solid #f1f5f9;">
                            <div style="flex: 1; min-width: 180px;">
                                <p style="font-size: 11px; text-transform: uppercase; color: #8c92a0; font-weight: 700; margin: 0 0 2px;">Guest Name</p>
                                <p style="font-size: 14px; font-weight: 600; color: #1f2937; margin: 0;">
                                    <%= booking.userId ? (booking.userId.firstName + ' ' + (booking.userId.lastName || '')) : 'Unknown Guest' %>
                                </p>
                            </div>
                            <div style="flex: 1; min-width: 180px;">
                                <p style="font-size: 11px; text-transform: uppercase; color: #8c92a0; font-weight: 700; margin: 0 0 2px;">Guest Email</p>
                                <p style="font-size: 14px; font-weight: 500; color: #4b5563; margin: 0;">
                                    <%= booking.userId ? booking.userId.email : 'N/A' %>
                                </p>
                            </div>
                        </div>

                        <!-- Stay details -->
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 10px;">
                            <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 8px 12px;">
                                <p style="font-size: 11px; color: #6b7280; margin: 0;">Check-In</p>
                                <p style="font-size: 13px; font-weight: 700; color: #1f2937; margin: 2px 0 0;"><%= new Date(booking.checkIn).toDateString() %></p>
                            </div>
                            <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 8px 12px;">
                                <p style="font-size: 11px; color: #6b7280; margin: 0;">Check-Out</p>
                                <p style="font-size: 13px; font-weight: 700; color: #1f2937; margin: 2px 0 0;"><%= new Date(booking.checkOut).toDateString() %></p>
                            </div>
                            <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 8px 12px;">
                                <p style="font-size: 11px; color: #6b7280; margin: 0;">Total Guests</p>
                                <p style="font-size: 13px; font-weight: 700; color: #1f2937; margin: 2px 0 0;">👥 <%= booking.guests %></p>
                            </div>
                        </div>

                        <!-- Financial details -->
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; background: #fafafa; border-radius: 10px; padding: 12px; border: 1px solid #e5e7eb;">
                            <div>
                                <p style="font-size: 11px; color: #6b7280; margin: 0;">Total Amount</p>
                                <p style="font-size: 14px; font-weight: 700; color: #111827; margin: 2px 0 0;">RS <%= booking.totalPrice %></p>
                            </div>
                            <div>
                                <p style="font-size: 11px; color: #6b7280; margin: 0;">Advance Paid</p>
                                <p style="font-size: 14px; font-weight: 700; color: #0d9488; margin: 2px 0 0;">RS <%= booking.advanceAmount %></p>
                            </div>
                            <div>
                                <p style="font-size: 11px; color: #6b7280; margin: 0;">Remaining Amount</p>
                                <p style="font-size: 14px; font-weight: 700; color: #ef4444; margin: 2px 0 0;">RS <%= booking.remainingAmount %></p>
                            </div>
                            <div>
                                <p style="font-size: 11px; color: #6b7280; margin: 0;">Payment Method</p>
                                <p style="font-size: 13px; font-weight: 700; color: #4b5563; margin: 2px 0 0;">💳 <%= booking.paymentMethod %></p>
                            </div>
                        </div>

                        <!-- Status/Action Details -->
                        <% if (booking.status === 'Approved') { %>
                            <div style="font-size: 12px; color: #0f766e; background-color: #f0fdfa; border: 1px solid #ccfbf1; border-radius: 8px; padding: 10px 14px;">
                                Approved on <%= new Date(booking.approvedAt).toLocaleString() %>
                            </div>
                        <% } else if (booking.status === 'Rejected') { %>
                            <div style="font-size: 12px; color: #b91c1c; background-color: #fef2f2; border: 1px solid #fca5a5; border-radius: 8px; padding: 10px 14px;">
                                <p style="margin: 0 0 4px; font-weight: 700;">Rejected on <%= new Date(booking.rejectedAt).toLocaleString() %></p>
                                <p style="margin: 0; font-style: italic;">Reason: <%= booking.rejectionReason %></p>
                            </div>
                        <% } else if (booking.status === 'Cancelled') { %>
                            <div style="font-size: 12px; color: #4b5563; background-color: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 10px 14px;">
                                Booking cancelled by guest.
                            </div>
                        <% } else if (booking.status === 'Pending Owner Approval') { %>
                            
                            <!-- Host Actions -->
                            <div style="border-top: 1px solid #f1f5f9; padding-top: 12px; display: flex; flex-direction: column; gap: 10px;">
                                <div style="display: flex; gap: 10px;">
                                    <form action="/host-bookings/<%= booking._id %>/approve" method="POST" style="flex: 1; margin: 0;" onsubmit="return confirm('Are you sure you want to approve this booking?');">
                                        <button type="submit" style="width: 100%; background-color: #0d9488; color: white; padding: 10px 0; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='#0f766e'" onmouseout="this.style.backgroundColor='#0d9488'">
                                            ✅ Approve Booking
                                        </button>
                                    </form>
                                    
                                    <button type="button" onclick="document.getElementById('reject-form-<%= booking._id %>').style.display = 'block'; this.style.display = 'none'; this.previousElementSibling.style.display = 'none';" style="flex: 1; background-color: #fef2f2; border: 1.5px solid #ef4444; color: #ef4444; padding: 10px 0; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.backgroundColor='#fee2e2'" onmouseout="this.style.backgroundColor='#fef2f2'">
                                        ❌ Reject Booking
                                    </button>
                                </div>
                                
                                <!-- Hidden Rejection Form -->
                                <form id="reject-form-<%= booking._id %>" action="/host-bookings/<%= booking._id %>/reject" method="POST" style="display: none; margin: 0; background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; padding: 12px; transition: all 0.2s;">
                                    <label style="font-size: 13px; font-weight: 600; color: #92400e; display: block; margin-bottom: 6px;">Provide Rejection Reason:</label>
                                    <input type="text" name="rejectionReason" placeholder="e.g. Fully booked on these dates, Host unavailable" required style="width: 100%; padding: 8px 10px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 13px; box-sizing: border-box; margin-bottom: 8px; outline-color: #ef4444;" />
                                    <div style="display: flex; gap: 8px; justify-content: flex-end;">
                                        <button type="button" onclick="document.getElementById('reject-form-<%= booking._id %>').style.display = 'none'; this.parentNode.parentNode.previousElementSibling.firstElementChild.style.display = 'block'; this.parentNode.parentNode.previousElementSibling.lastElementChild.style.display = 'block';" style="background: white; border: 1px solid #d1d5db; color: #4b5563; font-size: 12px; font-weight: 600; padding: 6px 12px; border-radius: 6px; cursor: pointer;">
                                            Cancel
                                        </button>
                                        <button type="submit" style="background: #ef4444; color: white; border: none; font-size: 12px; font-weight: 600; padding: 6px 12px; border-radius: 6px; cursor: pointer;">
                                            Confirm Rejection
                                        </button>
                                    </div>
                                </form>
                            </div>

                        <% } %>

                    </div>

                </div>

            <% }) %>

        <% } %>

    </main>

    <%- include('../partials/footer') %>
</body>
</html>
