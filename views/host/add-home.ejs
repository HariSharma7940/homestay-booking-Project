<%- include('../partials/header') %>
</head>
<body class="bg-gray-100 flex flex-col min-height-screen">
    <%- include('../partials/navigation') %>
    
    <main class="flex-1 flex justify-center mt-10 mb-10">
        <div class="bg-white p-10 rounded-xl shadow-lg" style="width: 100%; max-width: 480px;">
            <h1 class="text-2xl font-bold text-center mb-1 text-teal-800">Register Your Homestay</h1>
            <p class="text-center text-gray-500 text-sm mb-6">List details for guests to discover your home</p>
            <hr class="mb-6 border-gray-200"/>

            <form action="/host/add-home" method="POST" enctype="multipart/form-data">
                
                <div class="mb-4">
                    <label class="text-sm font-semibold text-gray-700 mb-1 block">Homestay Name</label>
                    <input 
                        type="text" 
                        name="houseName" 
                        placeholder="e.g. Cozy Lakeview Cottage" 
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-teal-50/20 focus:border-teal-500 outline-none"
                        required/>
                </div>

                <div class="mb-4">
                    <label class="text-sm font-semibold text-gray-700 mb-1 block">Price per Night (RS)</label>
                    <input 
                        type="number" 
                        name="price" 
                        placeholder="e.g. 1500" 
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-teal-50/20 focus:border-teal-500 outline-none"
                        required/>
                </div>

                <div class="mb-4">
                    <label class="text-sm font-semibold text-gray-700 mb-1 block">Location</label>
                    <input 
                        type="text" 
                        name="location" 
                        placeholder="e.g. Pokhara, Nepal" 
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-teal-50/20 focus:border-teal-500 outline-none"
                        required/>
                </div>

                <div class="mb-4">
                    <label class="text-sm font-semibold text-gray-700 mb-1 block">Photo (Image File)</label>
                    <input 
                        type="file" 
                        name="photo" 
                        accept="image/jpg, image/jpeg, image/png"
                        class="w-full border border-gray-300 p-2 rounded-lg bg-teal-50/20 focus:border-teal-500 outline-none"
                        required/>
                </div>

                <div class="mb-4">
                    <label class="text-sm font-semibold text-gray-700 mb-1 block">Initial Rating (1-5)</label>
                    <input 
                        type="number" 
                        name="rating" 
                        placeholder="e.g. 5" 
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-teal-50/20 focus:border-teal-500 outline-none" 
                        min="1" max="5"
                        required/>
                </div>

                <div class="mb-4">
                    <label class="text-sm font-semibold text-gray-700 mb-1 block">Max Guests Allowed</label>
                    <input 
                        type="number" 
                        name="guests" 
                        placeholder="e.g. 4" 
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-teal-50/20 focus:border-teal-500 outline-none" 
                        min="1"
                        required/>
                </div>

                <div class="mb-4">
                    <label class="text-sm font-semibold text-gray-700 mb-1 block">Number of Bedrooms</label>
                    <input 
                        type="number" 
                        name="bedrooms" 
                        placeholder="e.g. 2" 
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-teal-50/20 focus:border-teal-500 outline-none" 
                        min="1"
                        required/>
                </div>

                <div class="mb-4">
                    <label class="text-sm font-semibold text-gray-700 mb-1 block">Number of Bathrooms</label>
                    <input 
                        type="number" 
                        name="bathrooms" 
                        placeholder="e.g. 1" 
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-teal-50/20 focus:border-teal-500 outline-none" 
                        min="1"
                        required/>
                </div>

                <div class="mb-4">
                    <p class="text-sm font-semibold text-gray-700 mb-2">Amenities</p>
                    <div class="grid grid-cols-2 gap-2">
                        <label class="flex items-center gap-2 text-sm cursor-pointer">
                            <input type="checkbox" name="amenities" value="Wifi" class="accent-teal-600"/> 🛜 Wifi
                        </label>
                        <label class="flex items-center gap-2 text-sm cursor-pointer">
                            <input type="checkbox" name="amenities" value="Parking" class="accent-teal-600"/> 🅿️ Parking
                        </label>
                        <label class="flex items-center gap-2 text-sm cursor-pointer">
                            <input type="checkbox" name="amenities" value="Kitchen" class="accent-teal-600"/> 🍳 Kitchen
                        </label>
                        <label class="flex items-center gap-2 text-sm cursor-pointer">
                            <input type="checkbox" name="amenities" value="AC" class="accent-teal-600"/> ❄️ AC
                        </label>
                        <label class="flex items-center gap-2 text-sm cursor-pointer">
                            <input type="checkbox" name="amenities" value="Pool" class="accent-teal-600"/> 🏊 Pool
                        </label>
                        <label class="flex items-center gap-2 text-sm cursor-pointer">
                            <input type="checkbox" name="amenities" value="Washing Machine" class="accent-teal-600"/> 🫧 Washing Machine
                        </label>
                    </div>
                </div>

                <div class="mb-6">
                    <label class="text-sm font-semibold text-gray-700 mb-1 block">Description</label>
                    <textarea 
                        name="description" 
                        placeholder="Describe your cozy homestay details, surrounding activities, etc." 
                        class="w-full border border-gray-300 p-2.5 rounded-lg bg-teal-50/20 focus:border-teal-500 outline-none" 
                        rows="4"
                        required></textarea>
                </div>

                <button type="submit" style="background-color: #0d9488;" class="w-full text-white p-3 rounded-lg cursor-pointer hover:bg-teal-700 transition duration-300 font-semibold text-lg">
                    Add Homestay
                </button>
            </form>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>
