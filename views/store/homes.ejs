<%- include('../partials/header') %>
</head>
<body class="bg-gray-100 flex flex-col min-height-screen">
  <%- include('../partials/navigation') %>

  <main class="flex-1" style="max-width: 1100px; margin: 2rem auto; padding: 0 1.5rem; width: 100%; box-sizing: border-box;">
    
    <h1 style="text-align: center; color: #0d9488; font-size: 1.8rem; font-weight: 700; margin-bottom: 2rem;">
      Explore All Homestays
    </h1>

    <% if (registeredHomes.length === 0) { %>
      <div style="text-align: center; background: white; border-radius: 14px; padding: 3rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
        <p style="font-size: 3rem; margin: 0;">🏡</p>
        <h3 style="font-size: 1.25rem; font-weight: 600; color: #374151; margin: 1rem 0 0.5rem;">No homestays registered yet.</h3>
        <p style="color: #6b7280; margin: 0;">Check back later or register as a host to list your first home.</p>
      </div>
    <% } else { %>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;">
        
        <% registeredHomes.forEach(home => { %>
        <div style="background: white; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">
          
          <!-- Image -->
          <div style="width: 100%; height: 180px; overflow: hidden; position: relative;">
            <img src="<%= home.photo %>" alt="<%= home.houseName %>" style="width: 100%; height: 100%; object-fit: cover;" />
            <div style="position: absolute; top: 0.5rem; right: 0.5rem; background: rgba(255,255,255,0.9); padding: 2px 6px; border-radius: 20px; font-size: 11px; font-weight: 700; color: #0f766e;">
              ⭐ <%= home.rating %>
            </div>
          </div>

          <!-- Info -->
          <div style="padding: 1rem;">
            <h3 style="margin: 0 0 4px; font-size: 15px; font-weight: 700; color: #1f2937;"><%= home.houseName %></h3>
            <p style="margin: 0 0 10px; font-size: 13px; color: #6b7280;">📍 <%= home.location %></p>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
              <span style="font-size: 15px; font-weight: 700; color: #0d9488;">RS <%= home.price %> / night</span>
              <span style="font-size: 13px; color: #374151; font-weight: 500;">👥 <%= home.guests %> Guest<%= home.guests > 1 ? 's' : '' %></span>
            </div>
          </div>

          <!-- Actions -->
          <div style="display: flex; gap: 0.5rem; padding: 0 1rem 1rem; align-items: center;">
            <a href="/homes/<%= home._id %>" class="bg-teal-600 text-white p-2 rounded-lg hover:bg-teal-700 transition duration-300 font-semibold text-center" style="flex: 1; text-decoration: none; font-size: 14px;">
              Details
            </a>
            <% if (!isLoggedIn || (user && user.userType === 'guest')) { %>
            <div style="flex: 1.2; display: flex;">
              <%- include('../partials/favourites', {home: home}) %>
            </div>
            <% } %>
          </div>

        </div>
        <% }) %>

      </div>
    <% } %>
  </main>

  <%- include('../partials/footer') %>
