<%- include('../partials/header') %>
</head>
<body class="bg-gray-100 flex flex-col min-height-screen">
    <%- include('../partials/navigation') %>

    <main class="flex-1" style="max-width: 800px; margin: 2rem auto; padding: 0 1.5rem; width: 100%; box-sizing: border-box; font-family: sans-serif;">

        <!-- Header Section -->
        <div style="text-align: center; margin-bottom: 2rem;">
            <h1 style="color: #0d9488; font-size: 2rem; font-weight: 700; margin: 0;">My Bookings</h1>
            <p style="color: #6b7280; font-size: 14px; margin: 6px 0 0;">Here are all your upcoming trips</p>
            <% if (bookings.length > 0) { %>
                <span style="display: inline-block; margin-top: 10px; background-color: #0d9488; color: white; font-size: 13px; font-weight: 600; padding: 4px 14px; border-radius: 20px;">
                    <%= bookings.length %> Booking<%= bookings.length > 1 ? 's' : '' %> Found
                </span>
            <% } %>
        </div>

        <% if (bookings.length === 0) { %>

            <!-- Empty State -->
            <div style="text-align: center; background: white; border-radius: 16px; padding: 4rem 2rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                <p style="font-size: 4rem; margin: 0;">🏡</p>
                <h2 style="font-size: 1.3rem; font-weight: 700; color: #374151; margin: 1rem 0 0.5rem;">No trips booked yet!</h2>
                <p style="font-size: 14px; color: #6b7280; margin: 0 0 1.5rem;">Explore homestays and book your first cozy stay.</p>
                <a href="/homes" style="display: inline-block; background-color: #0d9488; color: white; padding: 10px 28px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 14px; transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='#0f766e'" onmouseout="this.style.backgroundColor='#0d9488'">
                    Browse Homestays
                </a>
            </div>

        <% } else { %>

            <% bookings.forEach(booking => { %>

                <!-- Booking Card -->
                <div style="background: white; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); margin-bottom: 1.5rem; overflow: hidden; display: flex; border-left: 5px solid #0d9488; flex-wrap: wrap;">

                    <!-- Home Image -->
                    <div style="width: 180px; min-width: 180px; height: 180px; overflow: hidden; display: flex;">
                        <img src="<%= booking.homeId ? booking.homeId.photo : '' %>" alt="<%= booking.homeId ? booking.homeId.houseName : 'Homestay' %>" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=400'"/>
                    </div>

                    <!-- Booking Info -->
                    <div style="flex: 1; padding: 1.2rem 1.5rem; display: flex; flex-direction: column; gap: 0.8rem; min-width: 250px;">

                        <!-- Top Row: Name + Status Badge -->
                        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
                            <h3 style="font-size: 16px; font-weight: 700; color: #1f2937; margin: 0;"><%= booking.homeId ? booking.homeId.houseName : 'Homestay' %></h3>
                            <span style="background-color: #ccfbf1; color: #0f766e; font-size: 12px; font-weight: 600; padding: 3px 10px; border-radius: 20px;">
                                ✅ Upcoming
                            </span>
                        </div>

                        <!-- Location -->
                        <p style="font-size: 13px; color: #6b7280; margin: 0;">📍 <%= booking.homeId ? booking.homeId.location : 'N/A' %></p>

                        <!-- Dates and Guests Grid -->
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(80px, 1fr)); gap: 0.8rem;">
                            <div style="background: #f9fafb; border-radius: 8px; padding: 8px; text-align: center; border: 1px solid #f1f5f9;">
                                <p style="font-size: 11px; color: #6b7280; margin: 0;">Check-in</p>
                                <p style="font-size: 13px; font-weight: 700; color: #111827; margin: 2px 0 0;"><%= new Date(booking.checkIn).toDateString() %></p>
                            </div>
                            <div style="background: #f9fafb; border-radius: 8px; padding: 8px; text-align: center; border: 1px solid #f1f5f9;">
                                <p style="font-size: 11px; color: #6b7280; margin: 0;">Check-out</p>
                                <p style="font-size: 13px; font-weight: 700; color: #111827; margin: 2px 0 0;"><%= new Date(booking.checkOut).toDateString() %></p>
                            </div>
                            <div style="background: #f9fafb; border-radius: 8px; padding: 8px; text-align: center; border: 1px solid #f1f5f9;">
                                <p style="font-size: 11px; color: #6b7280; margin: 0;">Guests</p>
                                <p style="font-size: 13px; font-weight: 700; color: #111827; margin: 2px 0 0;">👥 <%= booking.guests %></p>
                            </div>
                        </div>

                        <!-- Bottom Row: Total Price + Cancel Button -->
                        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; margin-top: auto; border-top: 1px solid #f1f5f9; padding-top: 8px;">
                            <span style="background-color: #f0fdfa; color: #0d9488; font-size: 15px; font-weight: 700; padding: 4px 14px; border-radius: 20px; border: 1px solid #ccfbf1;">
                                Total Paid: RS <%= booking.totalPrice %>
                            </span>
                            <form action="/bookings/delete/<%= booking._id %>" method="POST" style="margin: 0;">
                                <button type="submit" style="background-color: #fef2f2; border: 1.5px solid #ef4444; color: #ef4444; padding: 6px 14px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.backgroundColor='#fee2e2'" onmouseout="this.style.backgroundColor='#fef2f2'">
                                    ❌ Cancel Booking
                                </button>
                            </form>
                        </div>

                    </div>
                </div>

            <% }) %>

        <% } %>

    </main>

    <%- include('../partials/footer') %>