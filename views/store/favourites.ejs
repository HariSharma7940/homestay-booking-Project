<%- include('../partials/header') %>
</head>
<body class="bg-gray-100 flex flex-col min-height-screen">
    <%- include('../partials/navigation') %>

    <main class="flex-1" style="max-width: 1100px; margin: 2rem auto; padding: 0 1.5rem; width: 100%; box-sizing: border-box; font-family: sans-serif;">

        <h1 style="text-align: center; color: #0d9488; font-size: 1.8rem; font-weight: 700; margin-bottom: 2rem;">
            My Favourite Homestays
        </h1>

        <% if (favouriteHomes.length === 0) { %>
            <div style="text-align: center; background: white; border-radius: 14px; padding: 4rem 2rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                <p style="font-size: 3.5rem; margin: 0;">❤️</p>
                <h2 style="font-size: 1.25rem; font-weight: 700; color: #374151; margin: 1rem 0 0.5rem;">Your list is empty!</h2>
                <p style="color: #6b7280; margin: 0 0 1.5rem;">Explore our homestays and hit the favourite button to save them here.</p>
                <a href="/homes" style="display: inline-block; background-color: #0d9488; color: white; padding: 10px 24px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 14px; transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='#0f766e'" onmouseout="this.style.backgroundColor='#0d9488'">
                    Browse Homestays
                </a>
            </div>
        <% } else { %>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 2rem;">

                <% favouriteHomes.forEach(home => { %>
                <div style="background: white; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">

                    <!-- Image -->
                    <div style="width: 100%; height: 180px; overflow: hidden;">
                        <img src="<%= home.photo %>" alt="<%= home.houseName %>" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=400'" />
                    </div>

                    <!-- Info -->
                    <div style="padding: 1rem;">
                        <h3 style="margin: 0 0 4px; font-size: 15px; font-weight: 600; color: #1f2937;"><%= home.houseName %></h3>
                        <p style="margin: 0 0 10px; font-size: 13px; color: #6b7280;">📍 <%= home.location %></p>
                        <div style="display: flex; align-items: center; justify-content: space-between;">
                            <span style="font-size: 15px; font-weight: 700; color: #0d9488;">RS <%= home.price %> / night</span>
                            <span style="font-size: 13px; color: #374151; font-weight: 500;">⭐ <%= home.rating %></span>
                        </div>
                    </div>

                    <!-- Remove Form -->
                    <form action="/favourites/delete/<%= home._id %>" method="POST" style="margin: 0; padding: 0 1rem 1rem;">
                        <button type="submit" style="width: 100%; border: 1.5px solid #ef4444; color: #ef4444; background-color: #fef2f2; font-weight: 600; font-size: 13px; padding: 8px 0; border-radius: 8px; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.backgroundColor='#fee2e2'" onmouseout="this.style.backgroundColor='#fef2f2'">
                            ❌ Remove from Favourites
                        </button>
                    </form>
                </div>
                <% }) %>

            </div>
        <% } %>
    </main>

    <%- include('../partials/footer') %>
