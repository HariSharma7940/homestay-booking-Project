<%- include('../partials/header') %>
</head>
<body class="bg-gray-100 flex flex-col min-height-screen">
    <%- include('../partials/navigation') %>

    <main class="flex-1" style="max-width: 900px; margin: 2rem auto; padding: 0 1.5rem; width: 100%; box-sizing: border-box; font-family: sans-serif;">

        <!-- Hero Image -->
        <div style="position: relative; width: 100%; height: 380px; border-radius: 16px; overflow: hidden; margin-bottom: 1.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
            <img src="<%= home.photo %>" alt="<%= home.houseName %>" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=800'"/>
            <!-- Dark gradient overlay -->
            <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 60%; background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);"></div>
            <!-- Text on image -->
            <div style="position: absolute; bottom: 1.5rem; left: 1.5rem;">
                <h1 style="color: white; font-size: 2rem; font-weight: 700; margin: 0;"><%= home.houseName %></h1>
                <p style="color: #e2e8f0; font-size: 15px; margin: 6px 0 0;">📍 <%= home.location %></p>
            </div>
        </div>

        <!-- Quick Info Bar -->
        <div style="background: white; border-radius: 14px; padding: 1.25rem 1.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); display: flex; gap: 2rem; flex-wrap: wrap; margin-bottom: 1.5rem; justify-content: space-between;">
            <div style="text-align: center; flex: 1; min-width: 100px;">
                <p style="font-size: 13px; color: #6b7280; margin: 0 0 4px;">Price</p>
                <p style="font-size: 16px; font-weight: 700; color: #0d9488; margin: 0;">RS <%= home.price %> / night</p>
            </div>
            <div style="text-align: center; flex: 1; min-width: 100px;">
                <p style="font-size: 13px; color: #6b7280; margin: 0 0 4px;">Rating</p>
                <p style="font-size: 16px; font-weight: 700; color: #111827; margin: 0;">⭐ <%= home.rating %> / 5</p>
            </div>
            <div style="text-align: center; flex: 1; min-width: 100px;">
                <p style="font-size: 13px; color: #6b7280; margin: 0 0 4px;">Guests Allowed</p>
                <p style="font-size: 16px; font-weight: 700; color: #111827; margin: 0;">👥 <%= home.guests || 1 %></p>
            </div>
            <div style="text-align: center; flex: 1; min-width: 100px;">
                <p style="font-size: 13px; color: #6b7280; margin: 0 0 4px;">Bedrooms</p>
                <p style="font-size: 16px; font-weight: 700; color: #111827; margin: 0;">🛏 <%= home.bedrooms || 1 %></p>
            </div>
            <div style="text-align: center; flex: 1; min-width: 100px;">
                <p style="font-size: 13px; color: #6b7280; margin: 0 0 4px;">Bathrooms</p>
                <p style="font-size: 16px; font-weight: 700; color: #111827; margin: 0;">🚿 <%= home.bathrooms || 1 %></p>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">

            <!-- Left Column -->
            <div style="display: flex; flex-direction: column; gap: 1.5rem;">

                <!-- About This Home -->
                <div style="background: white; border-radius: 14px; padding: 1.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                    <h3 style="font-size: 16px; font-weight: 700; color: #0f766e; margin: 0 0 10px; border-bottom: 1px solid #f1f5f9; padding-bottom: 6px;">About This Homestay</h3>
                    <p style="font-size: 14px; color: #4b5563; margin: 0; line-height: 1.6;"><%= home.description || 'No description provided.' %></p>
                </div>

                <!-- Location details -->
                <div style="background: white; border-radius: 14px; padding: 1.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                    <h3 style="font-size: 16px; font-weight: 700; color: #0f766e; margin: 0 0 10px; border-bottom: 1px solid #f1f5f9; padding-bottom: 6px;">📍 Location Details</h3>
                    <p style="font-size: 14px; color: #4b5563; margin: 0;"><%= home.location %></p>
                </div>

            </div>

            <!-- Right Column -->
            <div style="display: flex; flex-direction: column; gap: 1.5rem;">

                <!-- Amenities -->
                <div style="background: white; border-radius: 14px; padding: 1.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                    <h3 style="font-size: 16px; font-weight: 700; color: #0f766e; margin: 0 0 12px; border-bottom: 1px solid #f1f5f9; padding-bottom: 6px;">What This Place Offers</h3>
                    <% if (home.amenities && home.amenities.length > 0) { %>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                            <% home.amenities.forEach(amenity => { %>
                                <div style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: #374151;">
                                    <% if (amenity === 'Wifi') { %> 🛜
                                    <% } else if (amenity === 'Parking') { %> 🅿️
                                    <% } else if (amenity === 'Kitchen') { %> 🍳
                                    <% } else if (amenity === 'AC') { %> ❄️
                                    <% } else if (amenity === 'Pool') { %> 🏊
                                    <% } else if (amenity === 'Washing Machine') { %> 🫧
                                    <% } %>
                                    <%= amenity %>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <p style="font-size: 14px; color: #6b7280; margin: 0;">No amenities listed.</p>
                    <% } %>
                </div>

                <% if (!isLoggedIn || (user && user.userType === 'guest')) { %>
                <!-- Action Buttons -->
                <div style="background: white; border-radius: 14px; padding: 1.25rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); display: flex; gap: 12px; align-items: center; justify-content: center;">
                    <div style="flex: 1; display: flex;">
                        <%- include('../partials/favourites', {home: home}) %>
                    </div>
                    <a href="/homes/<%= home._id %>/book" style="flex: 1; display: block; text-align: center; background-color: #0d9488; color: white; padding: 10px 0; border-radius: 8px; font-size: 14px; font-weight: 600; text-decoration: none; border: 1.5px solid #0d9488; transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='#0f766e'" onmouseout="this.style.backgroundColor='#0d9488'">
                        📅 Book Now
                    </a>
                </div>
                <% } %>

            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>